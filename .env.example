# Runtime
NODE_ENV=development
PORT=4001

# Console
NEXT_PUBLIC_API_URL=http://localhost:4001
APP_BASE_URL=http://localhost:3000

# Database and infra
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentcantdothat
REDIS_URL=redis://localhost:6379
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Auth0 core (console + resource owner fallback)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://agentcantdothat.api
AUTH0_CLIENT_ID=your-console-client-id
AUTH0_CLIENT_SECRET=your-console-client-secret
AUTH0_SECRET=replace-with-32-byte-hex-or-long-random-string
AUTH0_SCOPE=openid profile email offline_access
AUTH0_PASSWORD_REALM=Username-Password-Authentication

# Auth0 My Account audience for connect-account login
AUTH0_MY_ACCOUNT_AUDIENCE=https://your-tenant.auth0.com/me/

# Auth0 bootstrap app (tools/auth0/setup.mjs)
AUTH0_BOOTSTRAP_CLIENT_ID=your-management-bootstrap-client-id
AUTH0_BOOTSTRAP_CLIENT_SECRET=your-management-bootstrap-client-secret

# Auth0 custom API / CIBA
AUTH0_CUSTOM_API_CLIENT_ID=your-api-client-id
AUTH0_CUSTOM_API_CLIENT_SECRET=your-api-client-secret
AUTH0_CIBA_CLIENT_ID=your-ciba-client-id
AUTH0_CIBA_CLIENT_SECRET=your-ciba-client-secret
AUTH0_CIBA_AUDIENCE=https://agentcantdothat.api
AUTH0_CIBA_TIMEOUT_SECONDS=120

# Auth0 Token Vault for provider token exchange
AUTH0_TOKEN_VAULT_CLIENT_ID=your-token-vault-client-id
AUTH0_TOKEN_VAULT_CLIENT_SECRET=your-token-vault-client-secret
AUTH0_CONNECTION_NAME=google-oauth2
AUTH0_TOKEN_VAULT_REQUESTED_TOKEN_TYPE=http://auth0.com/oauth/token-type/federated-connection-access-token

# Optional login hints used during CIBA / provider token exchange
OPS_TOKEN_VAULT_LOGIN_HINT=
CFO_TOKEN_VAULT_LOGIN_HINT=
DPO_TOKEN_VAULT_LOGIN_HINT=

# Approver users and operations fallback user
OPS_USER_ID=
OPS_MANAGER_EMAIL=ops@example.com
OPS_MANAGER_PASSWORD=replace-with-strong-password
CFO_USER_ID=
DPO_USER_ID=

# Agent runtime model selection
AGENT_MODEL_PROVIDER=groq
AGENT_MODEL_NAME=llama-3.1-8b-instant
GROQ_API_KEY=

# Behavior toggles
TOKEN_VAULT_BILLING_EXPORT_REQUIRED=true
DEMO_MODE_ENABLED=false
DEMO_ADMIN_KEY=replace-with-long-random-admin-key

# Optional OpenTelemetry exporter
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318